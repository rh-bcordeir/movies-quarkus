---
apiVersion: v1
kind: Secret
metadata:
  name: github-webhook-secret
  namespace: {{ ci_namespace }}
type: Opaque
stringData:
  secretToken: "{{ webhook_secret_token }}"

---
# ── Bindings ─────────────────────────────────────────────────────────────────

apiVersion: triggers.tekton.dev/v1beta1
kind: TriggerBinding
metadata:
  name: github-push-binding
  namespace: {{ ci_namespace }}
spec:
  params:
    - name: git-revision
      value: $(body.head_commit.id)
    - name: git-repo-url
      value: $(body.repository.clone_url)
    - name: short-sha
      value: $(extensions.short_sha)

---
# ── TriggerTemplate: CI (develop → dev) ──────────────────────────────────────

apiVersion: triggers.tekton.dev/v1beta1
kind: TriggerTemplate
metadata:
  name: {{ app_name }}-ci-template
  namespace: {{ ci_namespace }}
spec:
  params:
    - name: git-revision
    - name: git-repo-url
    - name: short-sha
  resourcetemplates:
    - apiVersion: tekton.dev/v1
      kind: PipelineRun
      metadata:
        generateName: {{ app_name }}-ci-
        namespace: {{ ci_namespace }}
      spec:
        pipelineRef:
          name: {{ app_name }}-ci
        taskRunTemplate:
          serviceAccountName: pipeline-sa
        params:
          - name: app-repo-url
            value: $(tt.params.git-repo-url)
          - name: app-repo-revision
            value: $(tt.params.git-revision)
          - name: image-tag
            value: $(tt.params.short-sha)
        workspaces:
          - name: shared-workspace
            persistentVolumeClaim:
              claimName: pipeline-workspace
          - name: maven-cache
            persistentVolumeClaim:
              claimName: maven-cache

---
# ── TriggerTemplate: Promote dev → hml (release branch) ─────────────────────

apiVersion: triggers.tekton.dev/v1beta1
kind: TriggerTemplate
metadata:
  name: {{ app_name }}-promote-hml-template
  namespace: {{ ci_namespace }}
spec:
  params:
    - name: git-revision
    - name: git-repo-url
    - name: short-sha
  resourcetemplates:
    - apiVersion: tekton.dev/v1
      kind: PipelineRun
      metadata:
        generateName: {{ app_name }}-promote-hml-
        namespace: {{ ci_namespace }}
      spec:
        pipelineRef:
          name: {{ app_name }}-promote
        taskRunTemplate:
          serviceAccountName: pipeline-sa
        params:
          - name: source-values-file
            value: "{{ values_file_dev }}"
          - name: target-values-file
            value: "{{ values_file_hml }}"
        workspaces:
          - name: shared-workspace
            persistentVolumeClaim:
              claimName: pipeline-workspace

---
# ── TriggerTemplate: Promote hml → prd (main branch) ────────────────────────

apiVersion: triggers.tekton.dev/v1beta1
kind: TriggerTemplate
metadata:
  name: {{ app_name }}-promote-prd-template
  namespace: {{ ci_namespace }}
spec:
  params:
    - name: git-revision
    - name: git-repo-url
    - name: short-sha
  resourcetemplates:
    - apiVersion: tekton.dev/v1
      kind: PipelineRun
      metadata:
        generateName: {{ app_name }}-promote-prd-
        namespace: {{ ci_namespace }}
      spec:
        pipelineRef:
          name: {{ app_name }}-promote
        taskRunTemplate:
          serviceAccountName: pipeline-sa
        params:
          - name: source-values-file
            value: "{{ values_file_hml }}"
          - name: target-values-file
            value: "{{ values_file_prd }}"
        workspaces:
          - name: shared-workspace
            persistentVolumeClaim:
              claimName: pipeline-workspace

---
# ── EventListener ─────────────────────────────────────────────────────────────
# Three triggers share the same webhook URL but are filtered by branch via CEL.

apiVersion: triggers.tekton.dev/v1beta1
kind: EventListener
metadata:
  name: {{ app_name }}-listener
  namespace: {{ ci_namespace }}
spec:
  serviceAccountName: pipeline-sa
  triggers:
    - name: develop-push
      interceptors:
        - ref:
            name: github
          params:
            - name: secretRef
              value:
                secretName: github-webhook-secret
                secretKey: secretToken
            - name: eventTypes
              value: ["push"]
        - ref:
            name: cel
          params:
            - name: filter
              value: "body.ref == 'refs/heads/develop'"
            - name: overlays
              value:
                - key: short_sha
                  expression: "body.head_commit.id.truncate(7)"
      bindings:
        - ref: github-push-binding
      template:
        ref: {{ app_name }}-ci-template

    - name: release-push
      interceptors:
        - ref:
            name: github
          params:
            - name: secretRef
              value:
                secretName: github-webhook-secret
                secretKey: secretToken
            - name: eventTypes
              value: ["push"]
        - ref:
            name: cel
          params:
            - name: filter
              value: "body.ref == 'refs/heads/release'"
            - name: overlays
              value:
                - key: short_sha
                  expression: "body.head_commit.id.truncate(7)"
      bindings:
        - ref: github-push-binding
      template:
        ref: {{ app_name }}-promote-hml-template

    - name: main-push
      interceptors:
        - ref:
            name: github
          params:
            - name: secretRef
              value:
                secretName: github-webhook-secret
                secretKey: secretToken
            - name: eventTypes
              value: ["push"]
        - ref:
            name: cel
          params:
            - name: filter
              value: "body.ref == 'refs/heads/main'"
            - name: overlays
              value:
                - key: short_sha
                  expression: "body.head_commit.id.truncate(7)"
      bindings:
        - ref: github-push-binding
      template:
        ref: {{ app_name }}-promote-prd-template

---
# ── Route (single webhook URL for all three triggers) ────────────────────────

apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: el-{{ app_name }}-listener
  namespace: {{ ci_namespace }}
spec:
  to:
    kind: Service
    name: el-{{ app_name }}-listener
  port:
    targetPort: http-listener
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Redirect
